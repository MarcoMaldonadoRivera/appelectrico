# Base de datos
MONGODB_URI=mongodb://localhost:27017/servicios_electricos

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Puerto del servidor
PORT=5000

# Firebase (para autenticación)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id

# Google Cloud (Speech-to-Text y Dialogflow)
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project
GOOGLE_APPLICATION_CREDENTIALS=./config/google-credentials.json

# OpenAI (para GPT-4)
OPENAI_API_KEY=your_openai_api_key

# AWS (S3 y SES)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=servicios-electricos-documents

# Nodemailer (alternativa a AWS SES)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# API SEC (simulada para validación de certificaciones)
SEC_API_URL=https://api.sec.cl
SEC_API_KEY=your_sec_api_key

# ClaveÚnica (integración con ChileAtiende)
CLAVE_UNICA_CLIENT_ID=your_client_id
CLAVE_UNICA_CLIENT_SECRET=your_client_secret
CLAVE_UNICA_REDIRECT_URI=http://localhost:3000/auth/callback

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Entorno
NODE_ENV=development