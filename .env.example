# ElectriServ Chile - Variables de Entorno
# Copiar este archivo como .env y completar con valores reales

# ==============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==============================================

# MongoDB Connection String
# Desarrollo local: mongodb://localhost:27017/electriserv
# Producción: mongodb+srv://usuario:password@cluster.mongodb.net/electriserv
MONGODB_URI=mongodb://localhost:27017/electriserv

# ==============================================
# CONFIGURACIÓN DE FIREBASE
# ==============================================

# Firebase Project Config (obtener desde Firebase Console)
FIREBASE_API_KEY=AIzaSyDemoKey-ElectriServ-Chile
FIREBASE_AUTH_DOMAIN=electriserv-chile.firebaseapp.com
FIREBASE_PROJECT_ID=electriserv-chile
FIREBASE_STORAGE_BUCKET=electriserv-chile.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456789

# ==============================================
# AUTENTICACIÓN CLAVEUNICA
# ==============================================

# ClaveÚnica OAuth 2.0 Configuration
CLAVE_UNICA_CLIENT_ID=tu_client_id_claveunica
CLAVE_UNICA_CLIENT_SECRET=tu_client_secret_claveunica
CLAVE_UNICA_REDIRECT_URI=https://tu-dominio.com/auth/claveunica/callback
CLAVE_UNICA_SCOPE=openid run name email

# URLs ClaveÚnica (producción)
CLAVE_UNICA_AUTH_URL=https://accounts.claveunica.gob.cl/openid_connect/authorize
CLAVE_UNICA_TOKEN_URL=https://accounts.claveunica.gob.cl/openid_connect/token
CLAVE_UNICA_USERINFO_URL=https://accounts.claveunica.gob.cl/openid_connect/userinfo

# ==============================================
# CONFIGURACIÓN DE EMAIL (NODEMAILER)
# ==============================================

# SMTP Configuration (Gmail ejemplo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password

# Email Templates
FROM_EMAIL=noreply@electriserv.cl
FROM_NAME=ElectriServ Chile
SUPPORT_EMAIL=soporte@electriserv.cl

# ==============================================
# CONFIGURACIÓN DE SEGURIDAD
# ==============================================

# JWT Secret Key (generar uno seguro)
JWT_SECRET=tu_jwt_secret_muy_seguro_de_32_caracteres_minimo
JWT_EXPIRE=7d

# Encryption Key para datos sensibles
ENCRYPTION_KEY=tu_encryption_key_de_32_caracteres

# Session Secret
SESSION_SECRET=tu_session_secret_muy_seguro

# ==============================================
# APIs EXTERNAS
# ==============================================

# SEC e-RNII API (si está disponible)
SEC_API_URL=https://api.sec.cl/v1
SEC_API_KEY=tu_api_key_sec

# Hugging Face para IA (opcional)
HUGGINGFACE_API_KEY=tu_huggingface_api_key

# Google Maps API (para geolocalización de técnicos)
GOOGLE_MAPS_API_KEY=tu_google_maps_api_key

# ==============================================
# CONFIGURACIÓN DE DESARROLLO
# ==============================================

# Environment
NODE_ENV=development

# Server Port
PORT=5000

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Debug Mode
DEBUG=true

# ==============================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ==============================================

# Producción URLs
PRODUCTION_URL=https://electriserv-chile.vercel.app
API_BASE_URL=https://api.electriserv.cl

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ==============================================
# CONFIGURACIÓN DE STORAGE
# ==============================================

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Storage Provider (local, aws-s3, cloudinary)
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# AWS S3 (si se usa)
AWS_ACCESS_KEY_ID=tu_aws_access_key
AWS_SECRET_ACCESS_KEY=tu_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=electriserv-files

# ==============================================
# CONFIGURACIÓN DE LOGGING
# ==============================================

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Log File Path
LOG_FILE=./logs/app.log

# ==============================================
# CONFIGURACIÓN DE TESTING
# ==============================================

# Test Database
TEST_MONGODB_URI=mongodb://localhost:27017/electriserv_test

# Test Environment
TEST_JWT_SECRET=test_jwt_secret_for_testing_only

# ==============================================
# CONFIGURACIÓN DE MONITORING
# ==============================================

# Sentry for Error Tracking (opcional)
SENTRY_DSN=https://tu_sentry_dsn@sentry.io/proyecto

# Analytics (opcional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# ==============================================
# CONFIGURACIÓN DE WEBHOOKS
# ==============================================

# Webhook URLs para notificaciones
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/tu/webhook/url
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/tu/webhook

# ==============================================
# CONFIGURACIÓN DE CACHE
# ==============================================

# Redis Configuration (opcional para cache)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=tu_redis_password

# Cache TTL (tiempo de vida en segundos)
CACHE_TTL=3600

# ==============================================
# CONFIGURACIÓN DE BACKUP
# ==============================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=24h
BACKUP_RETENTION_DAYS=30

# ==============================================
# NOTAS IMPORTANTES
# ==============================================

# 1. NUNCA commitear el archivo .env real al repositorio
# 2. Usar valores seguros y únicos para cada environment
# 3. Rotar keys y secrets regularmente
# 4. Para ClaveÚnica, registrarse en https://claveunica.gob.cl/desarrolladores
# 5. Para Firebase, crear proyecto en https://console.firebase.google.com
# 6. Para MongoDB Atlas, crear cluster en https://cloud.mongodb.com
# 7. Generar JWT_SECRET con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"