{
  "name": "servicios-electricos-chile",
  "version": "1.0.0",
  "description": "Plataforma full-stack para gestión de servicios eléctricos domiciliarios en Chile con cumplimiento normativo SEC",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "install-all": "npm install && npm run install-client",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "servicios-electricos",
    "chile",
    "sec",
    "normativas",
    "electricidad",
    "domiciliario"
  ],
  "author": "Servicios Eléctricos Chile",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "nodemailer": "^6.9.7",
    "aws-sdk": "^2.1496.0",
    "@google-cloud/speech": "^6.0.1",
    "@google-cloud/dialogflow": "^6.0.0",
    "openai": "^4.20.1",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "pdfkit": "^0.14.0",
    "socket.io": "^4.7.4",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}